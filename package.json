{
  "name": "gist",
  "version": "1.0.0",
  "description": "> A dead-simple Chrome extension that enhances Google Search with AI-generated summaries using your own Google AI Flash 2.5 API key.",
  "main": "index.js",
  "directories": {
    "lib": "lib",
    "test": "tests"
  },
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --coverageReporters=html lcov text",
    "test:e2e": "jest e2e.test.js",
    "test:e2e-real": "jest --config=jest.e2e.config.js",
    "test:browser": "playwright test",
    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "jsdom": "^26.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.0",
    "@types/chrome": "^0.1.22",
    "@types/jest": "^30.0.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "puppeteer": "^24.24.0"
  }
}
